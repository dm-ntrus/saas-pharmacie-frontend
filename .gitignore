# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env (ne pas versionner les secrets ; garder .env.example)
.env
.env*.local

# vercel
.vercel

# IDE
.cursor
.cursorrules
.vscode

# eslint / prettier cache
.eslintcache
.prettiercache

# typescript
*.tsbuildinfo
