# ──────────────────────────────────────────────────────
# SaaS Pharmacie Frontend — Environment Variables
# Copy to .env.local and fill in values
# ──────────────────────────────────────────────────────

# ─── API (NestJS backend) ─────────────────────────────
# Base URL of the NestJS backend (no trailing slash, no /api/v1)
# Production
NEXT_PUBLIC_API_URL=https://backend.kipmoni.com
# Development override example:
# NEXT_PUBLIC_API_URL=http://localhost:5000

# ─── Site URL (this Next.js frontend) ─────────────────
# Production
NEXT_PUBLIC_SITE_URL=https://app.syntixpharma.com
# Development override example:
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Keycloak OIDC (REQUIRED) ────────────────────────
# Must match backend KEYCLOAK_BASE_URL
NEXT_PUBLIC_KEYCLOAK_URL=https://backend.kipmoni.com:8443
# Must match backend KEYCLOAK_REALM
NEXT_PUBLIC_KEYCLOAK_REALM=med-pharmacy
# Public client ID configured in Keycloak (PKCE flow, no secret)
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=pharma-saas-public-client
# OIDC scopes — MUST include 'organization' for Keycloak 26+ multi-tenant
NEXT_PUBLIC_KEYCLOAK_SCOPE=openid profile email organization

# ─── Multi-tenancy / Domain routing ──────────────────
# Main domain for the SaaS platform (subdomains = tenant slugs)
NEXT_PUBLIC_MAIN_DOMAIN=syntixpharma.com
# Comma-separated list of hostnames treated as root (non-tenant)
# NEXT_PUBLIC_ROOT_HOSTS=localhost:3000,syntixpharma.com
# Set to "true" to enable tenant host redirect in dev
# NEXT_PUBLIC_TENANT_HOST_REDIRECT_IN_DEV=false

# ─── Cookie domain (production only) ─────────────────
# Required for cross-subdomain cookie sharing (org switching).
# Must be dot-prefixed root domain. Leave empty on localhost.
# NEXT_PUBLIC_COOKIE_DOMAIN=.syntixpharma.com

# ─── Session / Security ──────────────────────────────
# Inactivity auto-logout timeout in ms (default: 1800000 = 30min)
# NEXT_PUBLIC_INACTIVITY_TIMEOUT_MS=1800000
# Token refresh buffer in ms before expiry (default: 60000 = 60s)
# NEXT_PUBLIC_TOKEN_REFRESH_BUFFER_MS=60000

# ─── Development ──────────────────────────────────────
# Comma-separated LAN IPs for Next.js HMR from other devices
# NEXT_DEV_ALLOWED_ORIGINS=192.168.1.100
